{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "GAIA Internal Docs",
  "description": "Internal developer documentation for the GAIA platform.",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/theexperiencecompany/gaia"
      }
    ]
  },
